# Service environment: local | development | production
NEXIUM_ENV=local

# PostgreSQL (primary DB — users, orders, wallets, trades)
POSTGRES_USER=nexium
POSTGRES_PASSWORD=nexium
POSTGRES_DB=nexium
POSTGRES_PORT=5432
DATABASE_URL=postgres://nexium:nexium@localhost:5432/nexium

# TimescaleDB (time-series — OHLCV, orderbook snapshots)
TIMESCALE_USER=nexium
TIMESCALE_PASSWORD=nexium
TIMESCALE_DB=nexium_market
TIMESCALE_PORT=5433
TIMESCALE_URL=postgres://nexium:nexium@localhost:5433/nexium_market

# Redis (cache, session, rate limiting)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT (auth service). Generate with: openssl rand -base64 32
JWT_SECRET=change-me-please

# Optional ad-hoc overrides — any AppConfig field via NEXIUM__SECTION__FIELD:
# NEXIUM__SERVER__PORT=8081
# NEXIUM__TELEMETRY__LOG_LEVEL=debug
# NEXIUM__TELEMETRY__OTLP_ENDPOINT=http://localhost:4317
